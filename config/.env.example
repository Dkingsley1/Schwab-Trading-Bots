# Copy this file to project root as `.env` and optionally create `.env.sim` / `.env.live`.
# Runtime loader order:
#   1) .env
#   2) .env.<profile>   (profile is sim or live)

# -------- Core Safety --------
MARKET_DATA_ONLY=1
ALLOW_ORDER_EXECUTION=0
ENABLE_RESOURCE_GUARD=1

# -------- Broker + Auth --------
# Default data broker used by start stack unless overridden.
DATA_BROKER=schwab

# Required for non-simulate Schwab runtime.
SCHWAB_API_KEY=YOUR_REAL_KEY
SCHWAB_SECRET=YOUR_REAL_SECRET
SCHWAB_REDIRECT=https://127.0.0.1:8182
PREMARKET_TOKEN_MIN_EXPIRES_SECONDS=600
PREMARKET_TOKEN_CHECK_INTERVAL_SECONDS=600
SCHWAB_AUTH_MIN_EXPIRES_SECONDS=600
SCHWAB_INTERACTIVE_FORCE_MAX_TOKEN_AGE_SECONDS=1

