# Copy this file to project root as `.env` and optionally create `.env.sim` / `.env.live`.
# Runtime loader order:
#   1) .env
#   2) .env.<profile>   (profile is sim or live)

# -------- Core Safety --------
MARKET_DATA_ONLY=1
ALLOW_ORDER_EXECUTION=0
ENABLE_RESOURCE_GUARD=1

# -------- Broker + Auth --------
# Default data broker used by start stack unless overridden.
DATA_BROKER=schwab

# Required for non-simulate Schwab runtime.
SCHWAB_API_KEY=YOUR_REAL_KEY
SCHWAB_SECRET=YOUR_REAL_SECRET
SCHWAB_REDIRECT=https://127.0.0.1:8182

# -------- Symbol Universe --------
SHADOW_SYMBOLS_CORE=SPY,QQQ,DIA,IWM,MDY,VOO,VTI,RSP,AAPL,MSFT,NVDA,AMZN,GOOGL,META,AVGO,ORCL,CRM,ADBE,NFLX,DIS,WBD,GS,JPM,BKNG,ABNB,MAR,HLT
SHADOW_SYMBOLS_VOLATILE=SOXL,SOXS,TQQQ,SQQQ,MSTR,SMCI,COIN,TSLA,PLTR,AMD,MRVL,ARM,IBIT,ETHA,MARA,RIOT,UVXY,VIXY,AAL,UAL,DAL,LUV,ALK,JBLU,CCL,RCL,NCLH,EXPE,JETS,XOP,OIH,OXY,SLB,HAL
SHADOW_SYMBOLS_DEFENSIVE=TLT,GLD,XLV,XLU,XLP,MO,HYG,LQD,UUP,XLE,XLF,XLI,XLK,XLY,IEF,SHY,TIP,TLH,JNK,AGG,BND,MUB,IGIB,USHY,FLOT,VGIT,SCHD,VIG,DGRO,HDV,NOBL,VYM,DIVO,JEPI,JEPQ,SPLV,VTV,JNJ,PG,KO,PEP,MCD,ABBV,ABT,MRK,PFE,T,VZ,O,VICI,MAIN,XOM,CVX,COP,EOG,MPC,PSX,VLO,KMI,ITA,LMT,NOC,RTX,GD,LHX,LDOS
SHADOW_SYMBOLS_COMMOD_FX_INTL=DBC,UNG,CORN,SLV,USO,FXE,FXY,EFA,EEM,EWJ,FXI,VEA,VWO,IEFA,VGK,INDA,SMH,SOXX,VGT,IGV,XOP,OIH,JETS,VNQ,IYR
DIVIDEND_SYMBOLS=SCHD,VIG,DGRO,HDV,NOBL,VYM,DIVO,JEPI,JEPQ,SPYD,DIV,FDVV,SCHY,JNJ,PG,KO,PEP,MCD,MO,ABBV,ABT,MRK,PFE,T,VZ,O,VICI,MAIN,XOM,CVX,COP,KMI,MPC,PSX,VLO,EOG,SLB
DIVIDEND_QUALITY_SYMBOLS=SCHD,VIG,DGRO,HDV,NOBL,VYM,DIVO,SCHY,JNJ,PG,KO,PEP,MCD,ABBV,ABT,MRK,XOM,CVX,COP,O,VICI,MSFT,AAPL
BOND_SYMBOLS=TLT,IEF,SHY,TLH,TIP,LQD,HYG,JNK,BND,AGG,MUB,IGIB,USHY,FLOT,VGIT

# -------- Lane Strategy Overlays (Day/Swing/Dividend/Bond) --------
DAY_EXEC_COST_MAX_SPREAD_BPS=20
DAY_LIQUIDITY_DEPTH_REF=1800
DAY_HALT_TRIGGER_NORM=0.90
DAY_HALT_RESUME_COOLDOWN_SECONDS=180
SWING_SQUEEZE_VOL_MAX=0.012
SWING_WEEKLY_TREND_ALPHA=0.18
DIVIDEND_TAX_MIN_HOLD_ITERS=45
DIVIDEND_REBALANCE_INTERVAL_ITERS=14
BOND_LONG_DURATION_SYMBOLS=TLT,TLH,VGLT,EDV,ZROZ,IEF
BOND_SHORT_DURATION_SYMBOLS=SHY,FLOT,VGSH,SCHO
BOND_IG_CREDIT_SYMBOLS=LQD,VCIT,IGIB
BOND_HY_CREDIT_SYMBOLS=HYG,JNK,USHY
BOND_INFLATION_SYMBOLS=TIP,VTIP,SCHP

# -------- Coinbase --------
COINBASE_WATCH_SYMBOLS=BTC-USD,ETH-USD,SOL-USD,AVAX-USD,LTC-USD,LINK-USD,DOGE-USD
COINBASE_WATCH_INTERVAL_SECONDS=20
COINBASE_START_SIMULATE=1

# -------- Paper Mirror --------
TOP_BOT_PAPER_TRADING_TOP_N=2
TOP_BOT_PAPER_TRADING_MIN_ACC=0.55
TOP_BOT_PAPER_TRADING_PROFILES=default
PAPER_BROKER_BRIDGE_ENABLED=1
PAPER_BROKER_BRIDGE_MODE=jsonl

# -------- Storage Routing --------
BOT_LOGS_PREFER_EXTERNAL=1
BOT_LOGS_EXTERNAL_MOUNT=/Volumes/BOT_LOGS
BOT_LOGS_EXTERNAL_PROJECT_DIR=schwab_trading_bot
BOT_LOGS_AUTO_SYNC_ON_RECONNECT=1
BOT_LOGS_AUTO_SYNC_PRUNE_LOCAL=1
BOT_LOGS_AUTO_SYNC_MAX_FILES=50000

# -------- Ops Alerts --------
# Optional webhook used by some guard scripts.
OPS_ALERT_WEBHOOK_URL=

# -------- Live Execution Guardrails (kept inactive until ALLOW_ORDER_EXECUTION=1) --------
SCHWAB_ACCOUNT_HASH=
LIVE_MAX_POSITION_QTY_PER_SYMBOL=250
LIVE_MAX_ORDER_NOTIONAL=25000
LIVE_MAX_OPEN_ORDERS_TOTAL=30
LIVE_MAX_OPEN_ORDERS_PER_SYMBOL=3
LIVE_MAX_DAILY_LOSS=1000
LIVE_API_FAIL_LIMIT=3
LIVE_API_COOLDOWN_SECONDS=120
LIVE_TRADE_MIN_INTERVAL_SECONDS=8
LIVE_TRADE_GLOBAL_MIN_INTERVAL_SECONDS=1.5
LIVE_MAX_SLIPPAGE_BPS=35
LIVE_API_RETRY_ATTEMPTS=4
LIVE_API_RETRY_BACKOFF_SECONDS=0.35
LIVE_API_RETRY_BACKOFF_MULTIPLIER=2.0
LIVE_API_RETRY_MAX_BACKOFF_SECONDS=3.0
LIVE_API_RETRY_JITTER_SECONDS=0.1
LIVE_API_RETRYABLE_STATUS_CODES=408,425,429,500,502,503,504
LIVE_POSITION_RECONCILE_TOLERANCE=0.0001
LIVE_PRETRADE_RECONCILE_REQUIRED=1
LIVE_PRETRADE_RECONCILE_BLOCK_ON_ERROR=1
LIVE_PRETRADE_RECONCILE_BLOCK_ON_MISMATCH=1
LIVE_PRETRADE_RECONCILE_SYNC_LOCAL=1

# -------- Live Softguards --------
# Manual operator red-button (set by scripts/operator_control.py).
OPERATOR_STOP=0
OPERATOR_STOP_FLAG_PATH=

# Auto softguard escalations.
LIVE_SOFTGUARD_AUTO_HALT_ON_API_CIRCUIT=1
LIVE_SOFTGUARD_AUTO_HALT_ON_POSITION_MISMATCH=1
LIVE_SOFTGUARD_AUTO_CANCEL_ON_OPERATOR_STOP=1
LIVE_SOFTGUARD_AUTO_CANCEL_ON_GLOBAL_HALT=1
LIVE_SOFTGUARD_AUTO_CANCEL_COOLDOWN_SECONDS=30

# Emergency liquidation remains OFF by default and should only be used rarely.
LIVE_SOFTGUARD_EMERGENCY_LIQUIDATION_ENABLED=0
LIVE_SOFTGUARD_EMERGENCY_LIQUIDATION_COOLDOWN_SECONDS=300

# -------- External Data APIs (Macro + Fundamentals) --------
# Official macro sources
FRED_API_KEY=
BLS_API_KEY=
BEA_API_KEY=
CENSUS_API_KEY=
TREASURY_FISCALDATA_API_KEY=
EIA_API_KEY=

# Global macro sources (currently keyless APIs)
WORLD_BANK_API_KEY=
OECD_API_KEY=
IMF_API_KEY=

# Filings/fundamentals
SEC_EDGAR_USER_AGENT=

# Supplemental market-data APIs
ALPHA_VANTAGE_API_KEY=
TWELVE_DATA_API_KEY=
NASDAQ_DATA_LINK_API_KEY=
# Note: BLS/Census can run keyless (lower limits). Treasury FiscalData, World Bank, OECD, and IMF are typically keyless.

# -------- No-Key Starter Set (Requested 1-4) --------
INGEST_TREASURY_FISCALDATA_ENABLED=1
INGEST_WORLD_BANK_ENABLED=1
INGEST_OECD_ENABLED=1
INGEST_IMF_ENABLED=1
INGEST_BLS_ENABLED=1
# BLS can run without key in public mode; set BLS_API_KEY for higher limits.
